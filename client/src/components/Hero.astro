---
---
<section id="hero" class="hero-section" aria-label="Introdução">
  <div class="hero-bg-video-wrapper">
    <video class="hero-bg-video" autoplay loop muted playsinline id="hero-video-el">
      <source src="/videos/video4.mp4" type="video/mp4">
    </video>
    <div class="hero-overlay"></div>
  </div>
  
  <div class="hero-content">
    <div class="hero-eyebrow">DIRETOR CRIATIVO & VIDEOMAKER</div>
    <h1 class="hero-title">
      <span class="title-line"><span>IMAGENS</span></span>
      <span class="title-line"><span>QUE VENDEM.</span></span>
      <span class="title-line"><span>HISTÓRIAS</span></span>
      <span class="title-line"><span>QUE FICAM.</span></span>
    </h1>
    <div class="hero-cta-wrapper">
      <button class="btn-play-showreel magnetic-btn" id="btn-showreel" aria-label="Assistir ao Showreel">
        <span class="btn-play-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="24" height="24">
            <path fill="currentColor" d="M8 5v14l11-7z"/>
          </svg>
        </span>
        <span class="btn-play-text"><span>ASSISTIR MEU REEL</span></span>
      </button>
    </div>
  </div>
  
  <div class="scroll-indicator" aria-hidden="true">
    <span class="scroll-text">SCROLL</span>
    <div class="scroll-mouse">
      <div class="scroll-wheel"></div>
    </div>
  </div>
</section>
