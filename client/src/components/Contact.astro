<section id="contact" class="contact-section" aria-label="Contato">
  <div class="contact-container">
    <span class="section-kicker">PRÓXIMO PASSO</span>
    <h2 class="contact-main-title">SUA PRÓXIMA CAMPANHA COMEÇA COM UMA CONVERSA.</h2>

    <div class="contact-cta-wrapper">
      <button class="btn-primary-glow magnetic-btn" id="btn-open-form">
        <span>FALAR SOBRE MEU PROJETO</span>
      </button>
    </div>

    <footer class="main-footer">
      <div class="footer-grid">
        <div class="footer-col-brand">
          <span class="footer-logo">J.A VIDEOMAKER</span>
          <p class="footer-tagline">Produção audiovisual de alto nível para marcas e agências.</p>
        </div>
        <div class="footer-col-contact">
          <span class="footer-label">CONTATO</span>
          <a href="mailto:j.avideomobile@gmail.com" class="footer-link">j.avideomobile@gmail.com</a>
          <a href="tel:+5588992737269" class="footer-link">+55 (88) 99273-7269</a>
        </div>
        <div class="footer-col-social">
          <span class="footer-label">SIGA-ME</span>
          <div class="footer-social-links">
            <a href="https://www.instagram.com/j.a_mobile/" target="_blank" rel="noopener noreferrer">Instagram</a>
            <a href="https://www.linkedin.com/in/joão-antônio-rodrigues-pereira-68165b3b3" target="_blank" rel="noopener noreferrer">LinkedIn</a>
            <a href="https://www.behance.net/javideomakeredit" target="_blank" rel="noopener noreferrer">Behance</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p class="copyright">&copy; 2026 J.A Videomaker. Todos os direitos reservados. Feito com paixão pela imagem.</p>
      </div>
    </footer>
  </div>
</section>

<!-- Contact Modal -->
<div class="contact-modal" id="contact-modal" aria-hidden="true" role="dialog" aria-label="Formulário de Contato">
  <div class="contact-modal-backdrop" id="contact-modal-backdrop"></div>
  <div class="contact-modal-content">
    <button class="contact-modal-close" id="contact-modal-close" aria-label="Fechar formulário">
      <svg viewBox="0 0 24 24" width="28" height="28">
        <path fill="currentColor" d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
      </svg>
    </button>
    
    <h3 class="contact-modal-title">INICIAR UM NOVO PROJETO</h3>
    <p class="contact-modal-subtitle">Conte-nos sobre sua ideia e entraremos em contato.</p>
    
    <form class="contact-form" id="project-form">
      <div class="form-group">
        <label for="form-name" class="form-label">Nome Completo</label>
        <input type="text" id="form-name" class="form-input" placeholder="Seu nome ou da sua marca" required>
      </div>
      
      <div class="form-group">
        <label for="form-email" class="form-label">E-mail de Contato</label>
        <input type="email" id="form-email" class="form-input" placeholder="exemplo@marca.com" required>
      </div>
      
      <div class="form-group">
        <label for="form-category" class="form-label">Tipo de Projeto</label>
        <select id="form-category" class="form-select">
          <option value="commercial">Comercial / Publicidade</option>
          <option value="brandstory">Brand Story / Corporativo</option>
          <option value="musicvideo">Music Video / Clipe</option>
          <option value="documentary">Documentário</option>
          <option value="other">Outro</option>
        </select>
      </div>
      
      <div class="form-group">
        <label for="form-message" class="form-label">Sobre o Projeto</label>
        <textarea id="form-message" class="form-textarea" rows="4" placeholder="Conte-nos sobre o conceito, objetivos e cronograma planejado..." required></textarea>
      </div>
      
      <button type="submit" class="btn-form-submit">
        <span>ENVIAR PROPOSTA</span>
      </button>
    </form>
    
    <div class="contact-success-message" id="success-msg" aria-live="polite">
      <div class="success-icon">✓</div>
      <h4>Mensagem Enviada!</h4>
      <p>Obrigado pelo contato. Retornaremos sua mensagem em até 24 horas.</p>
    </div>
  </div>
</div>
