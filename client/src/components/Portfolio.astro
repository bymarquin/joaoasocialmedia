---
---
<section id="portfolio" class="portfolio-section" aria-label="Projetos Selecionados">
  <div class="portfolio-sticky-wrapper" id="portfolio-sticky">
    <div class="portfolio-header">
      <span class="section-kicker">PORTFÓLIO</span>
      <h2 class="section-title">ALGUNS PROJETOS RECENTES</h2>
    </div>
    
    <!-- Horizontal track -->
    <div class="portfolio-track-container">
      <div class="portfolio-track" id="portfolio-track">
        
        <!-- Project 1 -->
        <article class="project-card" data-video-url="/videos/video1.mp4">
          <div class="project-media-wrapper">
            <img src="https://images.unsplash.com/photo-1536440136628-849c177e76a1?auto=format&fit=crop&w=800&q=80" alt="Set de filmagem publicitária" class="project-img">
            <video class="project-hover-video" src="/videos/video1.mp4" loop muted playsinline>
              <source src="/videos/video1.mp4" type="video/mp4">
            </video>
            <div class="project-media-overlay"></div>
          </div>
          <div class="project-details">
            <span class="project-category">PUBLICIDADE / RETAIL</span>
            <h3 class="project-title">THE NEON PULSE</h3>
            <button class="project-btn-play" aria-label="Reproduzir The Neon Pulse">VER PROJETO</button>
          </div>
        </article>

        <!-- Project 2 -->
        <article class="project-card" data-video-url="/videos/video2.mp4">
          <div class="project-media-wrapper">
            <img src="https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?auto=format&fit=crop&w=800&q=80" alt="Guitarrista gravando clipe musical" class="project-img">
            <video class="project-hover-video" src="/videos/video2.mp4" loop muted playsinline>
              <source src="/videos/video2.mp4" type="video/mp4">
            </video>
            <div class="project-media-overlay"></div>
          </div>
          <div class="project-details">
            <span class="project-category">MUSIC VIDEO / CLIPE</span>
            <h3 class="project-title">ACOUSTIC ECHOES</h3>
            <button class="project-btn-play" aria-label="Reproduzir Acoustic Echoes">VER PROJETO</button>
          </div>
        </article>

        <!-- Project 3 -->
        <article class="project-card" data-video-url="/videos/video3.mp4">
          <div class="project-media-wrapper">
            <img src="https://images.unsplash.com/photo-1485846234645-a62644f84728?auto=format&fit=crop&w=800&q=80" alt="Projetor de cinema analógico antigo" class="project-img">
            <video class="project-hover-video" src="/videos/video3.mp4" loop muted playsinline>
              <source src="/videos/video3.mp4" type="video/mp4">
            </video>
            <div class="project-media-overlay"></div>
          </div>
          <div class="project-details">
            <span class="project-category">DOCUMENTÁRIO / BRAND STORY</span>
            <h3 class="project-title">THE CINE LAB</h3>
            <button class="project-btn-play" aria-label="Reproduzir The Cine Lab">VER PROJETO</button>
          </div>
        </article>

        <!-- Project 4 -->
        <article class="project-card" data-video-url="/videos/video4.mp4">
          <div class="project-media-wrapper">
            <img src="https://images.unsplash.com/photo-1505686994434-e3cc5abf1330?auto=format&fit=crop&w=800&q=80" alt="Equipe gravando em ambiente externo natural" class="project-img">
            <video class="project-hover-video" src="/videos/video4.mp4" loop muted playsinline>
              <source src="/videos/video4.mp4" type="video/mp4">
            </video>
            <div class="project-media-overlay"></div>
          </div>
          <div class="project-details">
            <span class="project-category">NARRATIVO / SHORT FILM</span>
            <h3 class="project-title">SILENT GOLDEN HOUR</h3>
            <button class="project-btn-play" aria-label="Reproduzir Silent Golden Hour">VER PROJETO</button>
          </div>
        </article>

      </div>
    </div>
  </div>
</section>

<!-- Video Modal -->
<div class="video-modal" id="video-modal" aria-hidden="true" role="dialog" aria-label="Visualizador de Vídeo">
  <button class="modal-close" id="modal-close" aria-label="Fechar modal">
    <svg viewBox="0 0 24 24" width="28" height="28">
      <path fill="currentColor" d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
    </svg>
  </button>
  <div class="modal-backdrop" id="modal-backdrop"></div>
  <div class="modal-video-container">
    <video class="modal-video" id="modal-video" controls playsinline></video>
  </div>
</div>
