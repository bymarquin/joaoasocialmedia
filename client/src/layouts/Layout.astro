---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "J.A Videomaker | Videomaker & Editor Profissional de Vídeos",
	description = "Portfólio de João Antônio — videomaker e editor profissional baseado em Juazeiro. Produções audiovisuais de alto nível para marcas e agências."
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO Optimization -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content="videomaker, editor de vídeo, social media, portfólio de vídeo, produção audiovisual, Juazeiro" />
		<meta name="author" content="João Antônio Rodrigues Pereira" />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="https://images.unsplash.com/photo-1492691527719-9d1e07e534b4?auto=format&fit=crop&w=1200&q=80" />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Manrope:wght@300;400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body>
		<slot />

		<!-- Fullscreen WebGL Canvas Container -->
		<div id="canvas" aria-hidden="true"></div>

		<!-- Color Grading LUT Selector -->
		<div class="lut-switcher-container" id="lut-switcher">
			<button class="lut-toggle" id="lut-toggle" aria-label="Alterar LUT (Color Grading)">
				<svg viewBox="0 0 24 24" width="16" height="16">
					<circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none" />
					<path d="M12 2a10 10 0 0 1 0 20z" fill="currentColor" />
				</svg>
				<span class="lut-active-label">LUT: CINEMATIC</span>
			</button>
			<div class="lut-options" id="lut-options">
				<button class="lut-option active" data-lut="default">CINEMATIC</button>
				<button class="lut-option" data-lut="teal-orange">TEAL & ORANGE</button>
				<button class="lut-option" data-lut="noir">NOIR</button>
				<button class="lut-option" data-lut="vintage">VINTAGE</button>
			</div>
		</div>

		<!-- Fullscreen Cinematic Light Leak Transition Overlay -->
		<div class="light-leak-overlay" id="light-leak" aria-hidden="true"></div>

		<!-- Client side animation, scroll, and WebGL script -->
		<script>
			import { gsap } from 'gsap';
			import { ScrollTrigger } from 'gsap/ScrollTrigger';
			import Lenis from 'lenis';
			import { Curtains, Plane } from 'curtainsjs';

			// Register GSAP plugins
			gsap.registerPlugin(ScrollTrigger);

			// Add js-active class to body
			document.body.classList.add('js-active');

			// Check if user prefers reduced motion
			const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			// Global state variables
			let lenis: Lenis | undefined;
			let curtains: Curtains | undefined;
			let projectPlanes: any[] = [];

			// Mouse tracking for WebGL shaders (velocity calculation with inertia)
			let mouse = { x: 0, y: 0 };
			let lastMouse = { x: 0, y: 0 };
			let velocity = { x: 0, y: 0 };
			let targetVelocity = { x: 0, y: 0 };

			// Calculate mouse velocity on mousemove
			window.addEventListener('mousemove', (e) => {
				mouse.x = e.clientX;
				mouse.y = e.clientY;
			});

			// Interpolate mouse velocity dynamically for smooth rubbery settle
			const updateVelocity = () => {
				if (prefersReducedMotion) return;
				
				// Calculate change between frames
				const dx = mouse.x - lastMouse.x;
				const dy = mouse.y - lastMouse.y;
				
				// Feed raw velocity with viewport scaling
				targetVelocity.x = dx / window.innerWidth;
				targetVelocity.y = dy / window.innerHeight;
				
				// Smooth interpolation (dampening)
				velocity.x += (targetVelocity.x - velocity.x) * 0.1;
				velocity.y += (targetVelocity.y - velocity.y) * 0.1;
				
				// Settle down to 0 gradually
				targetVelocity.x *= 0.9;
				targetVelocity.y *= 0.9;
				
				// Store current coordinates as past
				lastMouse.x = mouse.x;
				lastMouse.y = mouse.y;
				
				requestAnimationFrame(updateVelocity);
			};
			requestAnimationFrame(updateVelocity);

			/* ==========================================================================
			SMOOTH SCROLLING (Lenis)
			========================================================================== */
			if (!prefersReducedMotion) {
				lenis = new Lenis({
					duration: 1.2,
					easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), // ease-out-expo
					orientation: 'vertical',
					gestureOrientation: 'vertical',
					smoothWheel: true,
					wheelMultiplier: 1,
					touchMultiplier: 2,
				});

				lenis.on('scroll', ScrollTrigger.update);

				const raf = (time: number) => {
					lenis?.raf(time);
					requestAnimationFrame(raf);
				};
				requestAnimationFrame(raf);

				// Enable default GSAP lag smoothing to absorb micro-stutters during minor frame drops
				gsap.ticker.lagSmoothing(500, 33);
			}

			/* ==========================================================================
			CUSTOM CURSOR & FLOAT PREVIEW IMAGE
			========================================================================== */
			const cursor = document.getElementById('cursor');
			const cursorFollower = document.getElementById('cursor-follower');
			const cursorImageContainer = document.getElementById('cursor-image-container');
			const cursorImage = document.getElementById('cursor-image') as HTMLImageElement | null;

			if (!prefersReducedMotion && cursor && cursorFollower) {
				const setCursorX = gsap.quickTo(cursor, 'left', { duration: 0.1, ease: 'power2.out' });
				const setCursorY = gsap.quickTo(cursor, 'top', { duration: 0.1, ease: 'power2.out' });
				
				const setFollowerX = gsap.quickTo(cursorFollower, 'left', { duration: 0.3, ease: 'power3.out' });
				const setFollowerY = gsap.quickTo(cursorFollower, 'top', { duration: 0.3, ease: 'power3.out' });
				
				const setImageContainerX = gsap.quickTo(cursorImageContainer, 'left', { duration: 0.4, ease: 'power3.out' });
				const setImageContainerY = gsap.quickTo(cursorImageContainer, 'top', { duration: 0.4, ease: 'power3.out' });

				window.addEventListener('mousemove', (e) => {
					const { clientX, clientY } = e;
					
					setCursorX(clientX);
					setCursorY(clientY);
					
					setFollowerX(clientX);
					setFollowerY(clientY);
					
					setImageContainerX(clientX);
					setImageContainerY(clientY);
				});

				// Standard hover state logic
				const updateInteractiveElements = () => {
					const interactiveElements = document.querySelectorAll('a, button, select, textarea, input');
					interactiveElements.forEach((el) => {
						el.addEventListener('mouseenter', () => {
							cursor.classList.add('hovered');
							cursorFollower.classList.add('hovered');
						});
						el.addEventListener('mouseleave', () => {
							cursor.classList.remove('hovered');
							cursorFollower.classList.remove('hovered');
						});
					});
				};

				updateInteractiveElements();

				// Project cards (PLAY text state)
				const projectCards = document.querySelectorAll('.project-card');
				projectCards.forEach((card) => {
					card.addEventListener('mouseenter', () => {
						cursor.classList.add('play-state');
						cursorFollower.classList.add('play-state');
					});
					card.addEventListener('mouseleave', () => {
						cursor.classList.remove('play-state');
						cursorFollower.classList.remove('play-state');
					});
				});
			}

			/* ==========================================================================
			PRELOADER & HERO ENTRANCE ANIMATIONS
			========================================================================== */
			const preloader = document.getElementById('preloader');
			const progressFill = document.getElementById('progress-fill');
			const loaderPercentage = document.getElementById('loader-percentage');

			const runEntranceAnimations = () => {
				const tl = gsap.timeline();
				
				tl.to('.hero-bg-video', {
					scale: 1,
					duration: 2.2,
					ease: 'power3.out'
				});

				tl.to('.hero-title span', {
					y: 0,
					duration: 1.2,
					stagger: 0.15,
					ease: 'power4.out'
				}, '-=1.8');

				tl.to('.hero-eyebrow', {
					y: 0,
					opacity: 1,
					duration: 1,
					ease: 'power3.out'
				}, '-=0.8');

				tl.to('.hero-cta-wrapper', {
					y: 0,
					opacity: 1,
					duration: 1,
					ease: 'power3.out'
				}, '-=0.8');

				tl.to('.scroll-indicator', {
					opacity: 1,
					duration: 1.5,
					ease: 'power2.out'
				}, '-=0.5');
			};

			const initPreloader = () => {
				let percentage = 0;
				const interval = setInterval(() => {
					const step = Math.floor(Math.random() * 15) + 3;
					percentage = Math.min(100, percentage + step);
					
					if (progressFill) progressFill.style.width = `${percentage}%`;
					if (loaderPercentage) loaderPercentage.textContent = percentage.toString().padStart(2, '0');
					
					if (percentage >= 100) {
						clearInterval(interval);
						
						if (preloader) {
							gsap.to(preloader, {
								opacity: 0,
								pointerEvents: 'none',
								duration: 0.8,
								ease: 'power3.inOut',
								onComplete: () => {
									preloader.style.display = 'none';
									runEntranceAnimations();
									ScrollTrigger.refresh();
								}
							});
						} else {
							runEntranceAnimations();
							ScrollTrigger.refresh();
						}
					}
				}, 100);
			};

			if (document.readyState === 'loading') {
				window.addEventListener('DOMContentLoaded', initPreloader);
			} else {
				initPreloader();
			}

			/* ==========================================================================
			SCROLLED HEADER STYLING
			========================================================================== */
			const header = document.getElementById('header');
			window.addEventListener('scroll', () => {
				if (header) {
					if (window.scrollY > 50) {
						header.classList.add('scrolled');
					} else {
						header.classList.remove('scrolled');
					}
				}
			});

			/* ==========================================================================
			MOBILE MENU DRAWER
			========================================================================== */
			const menuToggle = document.getElementById('menu-toggle');
			const mobileNav = document.getElementById('mobile-nav');
			const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

			if (menuToggle && mobileNav) {
				const toggleMobileMenu = () => {
					const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
					menuToggle.setAttribute('aria-expanded', String(!isExpanded));
					mobileNav.setAttribute('aria-hidden', String(isExpanded));
					mobileNav.classList.toggle('active');
					
					document.body.style.overflow = isExpanded ? 'auto' : 'hidden';
					if (lenis) {
						if (isExpanded) lenis.start();
						else lenis.stop();
					}
				};

				menuToggle.addEventListener('click', toggleMobileMenu);

				mobileNavLinks.forEach((link) => {
					link.addEventListener('click', () => {
						toggleMobileMenu();
					});
				});
			}

			/* ==========================================================================
			HORIZONTAL SCROLL (PORTFOLIO SECTION)
			========================================================================== */
			const portfolioSection = document.getElementById('portfolio');
			const portfolioSticky = document.getElementById('portfolio-sticky');
			const portfolioTrack = document.getElementById('portfolio-track');

			if (portfolioTrack && portfolioSticky && !prefersReducedMotion) {
				const mq = window.matchMedia('(min-width: 1025px)');
				
				let scrollTween: any;

				const initHorizontalScroll = () => {
					if (mq.matches) {
						const trackWidth = portfolioTrack.scrollWidth;
						const amountToScroll = trackWidth - window.innerWidth;
						
						portfolioSection.style.height = `${amountToScroll + window.innerHeight}px`;

						scrollTween = gsap.to(portfolioTrack, {
							x: -amountToScroll,
							ease: 'none',
							onUpdate: () => {
								projectPlanes.forEach((p) => p.updatePosition());
							},
							scrollTrigger: {
								trigger: portfolioSection,
								start: 'top top',
								end: `+=${amountToScroll}`,
								scrub: 1,
								invalidateOnRefresh: true,
							}
						});
					} else {
						portfolioSection.style.height = 'auto';
						if (scrollTween) {
							scrollTween.scrollTrigger.kill(true);
							scrollTween.kill();
						}
						gsap.set(portfolioTrack, { x: 0 });
					}
				};

				const handleInit = () => {
					initHorizontalScroll();
					initScrollRevealAnimations();
					initMagneticButtons();
					initLutSwitcher();
					ScrollTrigger.refresh();
				};

				if (document.readyState === 'complete') {
					handleInit();
				} else {
					window.addEventListener('load', handleInit);
				}

				window.addEventListener('resize', () => {
					initHorizontalScroll();
					ScrollTrigger.refresh();
				});
			}

			/* ==========================================================================
			SCROLL REVEAL & TEXT SPLIT ANIMATIONS
			========================================================================== */
			const splitText = (selector: string) => {
				const elements = document.querySelectorAll(selector);
				elements.forEach((el) => {
					const text = el.textContent || '';
					const words = text.trim().split(/\s+/);
					el.innerHTML = words
						.map(
							(word) =>
								`<span class="split-word-wrapper" style="display: inline-block; overflow: hidden; vertical-align: top;"><span class="split-word-inner" style="display: inline-block; transform: translateY(110%); will-change: transform;">${word}</span></span>`
						)
						.join(' ');
				});
			};

			const initScrollRevealAnimations = () => {
				if (prefersReducedMotion) return;

				// Split text for titles
				splitText('.about-text-content .section-title');
				splitText('.services-container .section-title');
				splitText('.contact-main-title');
				splitText('.about-lead');

				// Animate About Section Title
				gsap.to('.about-text-content .section-title .split-word-inner', {
					y: '0%',
					duration: 1.2,
					stagger: 0.04,
					ease: 'power4.out',
					scrollTrigger: {
						trigger: '.about-text-content .section-title',
						start: 'top 85%',
					}
				});

				// Animate About Section Lead
				gsap.to('.about-lead .split-word-inner', {
					y: '0%',
					duration: 1.2,
					stagger: 0.02,
					ease: 'power3.out',
					scrollTrigger: {
						trigger: '.about-lead',
						start: 'top 85%',
					}
				});

				// Animate About Section Body text
				gsap.fromTo('.about-body',
					{ opacity: 0, y: 30 },
					{
						opacity: 1,
						y: 0,
						duration: 1.2,
						ease: 'power3.out',
						scrollTrigger: {
							trigger: '.about-body',
							start: 'top 90%',
						}
					}
				);

				// Parallax effect for About Image
				const aboutImg = document.querySelector('.about-img');
				if (aboutImg) {
					gsap.set(aboutImg, { yPercent: -10 });
					gsap.to(aboutImg, {
						yPercent: 10,
						ease: 'none',
						scrollTrigger: {
							trigger: '.about-section',
							start: 'top bottom',
							end: 'bottom top',
							scrub: true,
						}
					});
				}

				// Animate Services Section Title
				gsap.to('.services-container .section-title .split-word-inner', {
					y: '0%',
					duration: 1.2,
					stagger: 0.04,
					ease: 'power4.out',
					scrollTrigger: {
						trigger: '.services-container .section-title',
						start: 'top 85%',
					}
				});

				// Animate Services List Items
				const serviceItems = document.querySelectorAll('.service-item');
				if (serviceItems.length > 0) {
					gsap.fromTo(serviceItems,
						{ opacity: 0, y: 50 },
						{
							opacity: 1,
							y: 0,
							duration: 1,
							stagger: 0.15,
							ease: 'power3.out',
							scrollTrigger: {
								trigger: '.services-list',
								start: 'top 80%',
							}
						}
					);
				}

				// Animate Contact Section Title
				gsap.to('.contact-main-title .split-word-inner', {
					y: '0%',
					duration: 1.2,
					stagger: 0.04,
					ease: 'power4.out',
					scrollTrigger: {
						trigger: '.contact-main-title',
						start: 'top 85%',
					}
				});

				// Animate Contact Button
				gsap.fromTo('#btn-open-form',
					{ opacity: 0, scale: 0.9, y: 20 },
					{
						opacity: 1,
						scale: 1,
						y: 0,
						duration: 1,
						ease: 'back.out(1.7)',
						scrollTrigger: {
							trigger: '.contact-cta-wrapper',
							start: 'top 90%',
						}
					}
				);
			};

			/* ==========================================================================
			MAGNETIC BUTTONS INTERACTIVE HOVER
			========================================================================== */
			const initMagneticButtons = () => {
				if (prefersReducedMotion) return;

				const magneticButtons = document.querySelectorAll('.magnetic-btn');
				magneticButtons.forEach((btn) => {
					btn.addEventListener('mousemove', (e: Event) => {
						const mouseEvent = e as MouseEvent;
						const rect = btn.getBoundingClientRect();
						const x = mouseEvent.clientX - rect.left - rect.width / 2;
						const y = mouseEvent.clientY - rect.top - rect.height / 2;
						
						gsap.to(btn, {
							x: x * 0.35,
							y: y * 0.35,
							duration: 0.3,
							ease: 'power2.out'
						});
						
						const innerText = btn.querySelector('span');
						if (innerText) {
							gsap.to(innerText, {
								x: x * 0.15,
								y: y * 0.15,
								duration: 0.3,
								ease: 'power2.out'
							});
						}
					});
					
					btn.addEventListener('mouseleave', () => {
						gsap.to(btn, {
							x: 0,
							y: 0,
							duration: 0.6,
							ease: 'elastic.out(1.1, 0.4)'
						});
						
						const innerText = btn.querySelector('span');
						if (innerText) {
							gsap.to(innerText, {
								x: 0,
								y: 0,
								duration: 0.6,
								ease: 'elastic.out(1.1, 0.4)'
							});
						}
					});
				});
			};

			/* ==========================================================================
			COLOR GRADING LUT SWITCHER (FILMMAKER THEME EXCLUSIVITY)
			========================================================================== */
			const initLutSwitcher = () => {
				const lutSwitcher = document.getElementById('lut-switcher');
				const lutToggle = document.getElementById('lut-toggle');
				const lutLabel = lutToggle?.querySelector('.lut-active-label');
				const lutOptions = document.querySelectorAll('.lut-option');

				if (!lutSwitcher || !lutToggle) return;

				// Toggle panel open/close
				lutToggle.addEventListener('click', (e) => {
					e.stopPropagation();
					lutSwitcher.classList.toggle('active');
				});

				// Close panel on clicking outside
				document.addEventListener('click', () => {
					lutSwitcher.classList.remove('active');
				});

				// LUT Options click handling
				lutOptions.forEach((btn) => {
					btn.addEventListener('click', (e) => {
						e.stopPropagation();
						
						// Remove active class from all options
						lutOptions.forEach(opt => opt.classList.remove('active'));
						btn.classList.add('active');

						const lutName = btn.getAttribute('data-lut') || 'default';
						
						// Remove existing LUT classes from body
						document.body.classList.remove('lut-teal-orange', 'lut-noir', 'lut-vintage');
						
						// Apply new LUT class and update label
						if (lutName !== 'default') {
							document.body.classList.add(`lut-${lutName}`);
							if (lutLabel) lutLabel.textContent = `LUT: ${lutName.replace('-', ' ')}`;
						} else {
							if (lutLabel) lutLabel.textContent = 'LUT: DEFAULT';
						}

						// Close panel
						lutSwitcher.classList.remove('active');

						// Refresh ScrollTrigger and WebGL just in case coordinates shifted slightly
						ScrollTrigger.refresh();
					});
				});
			};

			// Hover project card -> Play muted video loop
			const hoverVideoCards = document.querySelectorAll('.project-card');
			hoverVideoCards.forEach((card) => {
				const video = card.querySelector('.project-hover-video') as HTMLVideoElement | null;
				if (video) {
					card.addEventListener('mouseenter', () => {
						video.play().catch(() => {});
					});
					card.addEventListener('mouseleave', () => {
						video.pause();
						video.currentTime = 0;
					});
				}
			});

			/* ==========================================================================
			VIDEO PLAYER MODAL
			========================================================================== */
			const videoModal = document.getElementById('video-modal');
			const modalVideo = document.getElementById('modal-video') as HTMLVideoElement | null;
			const modalClose = document.getElementById('modal-close');
			const modalBackdrop = document.getElementById('modal-backdrop');
			const btnShowreel = document.getElementById('btn-showreel');

			const defaultReelUrl = '/videos/video4.mp4';

			const openVideoModal = (videoUrl: string) => {
				if (videoModal && modalVideo) {
					const lightLeak = document.getElementById('light-leak');
					
					if (lightLeak && !prefersReducedMotion) {
						gsap.timeline()
							.fromTo(lightLeak, 
								{ opacity: 0, scale: 0.8, xPercent: -20, yPercent: 20 },
								{
									opacity: 1,
									scale: 1.5,
									xPercent: 0,
									yPercent: 0,
									duration: 0.5,
									ease: 'power3.in',
									onComplete: () => {
										modalVideo.src = videoUrl || defaultReelUrl;
										videoModal.classList.add('active');
										videoModal.setAttribute('aria-hidden', 'false');
										modalVideo.play();
										
										document.body.style.overflow = 'hidden';
										if (lenis) lenis.stop();
									}
								}
							)
							.to(lightLeak, {
								opacity: 0,
								scale: 2,
								xPercent: 20,
								yPercent: -20,
								duration: 0.6,
								ease: 'power3.out'
							});
					} else {
						modalVideo.src = videoUrl || defaultReelUrl;
						videoModal.classList.add('active');
						videoModal.setAttribute('aria-hidden', 'false');
						modalVideo.play();
						
						document.body.style.overflow = 'hidden';
						if (lenis) lenis.stop();
					}
				}
			};

			const closeVideoModal = () => {
				if (videoModal && modalVideo) {
					videoModal.classList.remove('active');
					videoModal.setAttribute('aria-hidden', 'true');
					modalVideo.pause();
					modalVideo.currentTime = 0;
					modalVideo.src = '';
					
					document.body.style.overflow = 'auto';
					if (lenis) lenis.start();
				}
			};

			if (btnShowreel) {
				btnShowreel.addEventListener('click', () => openVideoModal(defaultReelUrl));
			}

			const playButtons = document.querySelectorAll('.project-btn-play');
			playButtons.forEach((btn) => {
				btn.addEventListener('click', (e) => {
					e.stopPropagation();
					const card = btn.closest('.project-card');
					if (card) {
						const videoUrl = card.getAttribute('data-video-url');
						if (videoUrl) openVideoModal(videoUrl);
					}
				});
			});

			if (modalClose && modalBackdrop) {
				modalClose.addEventListener('click', closeVideoModal);
				modalBackdrop.addEventListener('click', closeVideoModal);
				
				window.addEventListener('keydown', (e) => {
					if (e.key === 'Escape' && videoModal && videoModal.classList.contains('active')) {
						closeVideoModal();
					}
				});
			}

			/* ==========================================================================
			CONTACT MODAL FORM
			========================================================================== */
			const contactModal = document.getElementById('contact-modal');
			const contactModalBackdrop = document.getElementById('contact-modal-backdrop');
			const contactModalClose = document.getElementById('contact-modal-close');
			const btnOpenForm = document.getElementById('btn-open-form');
			const btnNavContact = document.getElementById('btn-nav-contact');
			const mobileNavContact = document.getElementById('mobile-nav-contact');
			const projectForm = document.getElementById('project-form') as HTMLFormElement | null;
			const successMsg = document.getElementById('success-msg');

			const openContactModal = (e: Event) => {
				if (e) e.preventDefault();
				if (contactModal) {
					contactModal.classList.add('active');
					contactModal.setAttribute('aria-hidden', 'false');
					
					document.body.style.overflow = 'hidden';
					if (lenis) lenis.stop();
				}
			};

			const closeContactModal = () => {
				if (contactModal) {
					contactModal.classList.remove('active');
					contactModal.setAttribute('aria-hidden', 'true');
					
					setTimeout(() => {
						if (projectForm) {
							projectForm.reset();
							projectForm.style.display = 'flex';
						}
						if (successMsg) successMsg.classList.remove('active');
					}, 500);
					
					document.body.style.overflow = 'auto';
					if (lenis) lenis.start();
				}
			};

			if (btnOpenForm) btnOpenForm.addEventListener('click', openContactModal);
			if (btnNavContact) btnNavContact.addEventListener('click', openContactModal);
			if (mobileNavContact) mobileNavContact.addEventListener('click', openContactModal);

			if (contactModalClose && contactModalBackdrop) {
				contactModalClose.addEventListener('click', closeContactModal);
				contactModalBackdrop.addEventListener('click', closeContactModal);
				
				window.addEventListener('keydown', (e) => {
					if (e.key === 'Escape' && contactModal && contactModal.classList.contains('active')) {
						closeContactModal();
					}
				});
			}

			if (projectForm) {
				projectForm.addEventListener('submit', (e) => {
					e.preventDefault();
					
					const submitBtn = projectForm.querySelector('.btn-form-submit') as HTMLButtonElement | null;
					const submitBtnText = submitBtn?.querySelector('span');
					if (submitBtn && submitBtnText) {
						submitBtnText.textContent = 'ENVIANDO...';
						submitBtn.style.opacity = '0.7';
						submitBtn.disabled = true;
					}
					
					setTimeout(() => {
						if (projectForm) projectForm.style.display = 'none';
						if (successMsg) successMsg.classList.add('active');
						
						if (submitBtn && submitBtnText) {
							submitBtnText.textContent = 'ENVIAR PROPOSTA';
							submitBtn.style.opacity = '1';
							submitBtn.disabled = false;
						}
						
						setTimeout(closeContactModal, 3500);
					}, 1500);
				});
			}

			/* ==========================================================================
			WEBGL SHADERS & DISTORTIONS (Curtains.js integration)
			========================================================================== */
			if (!prefersReducedMotion) {
				// Shader sources
				const projectVertexShader = `
					precision mediump float;
					
					attribute vec3 aVertexPosition;
					attribute vec2 aTextureCoord;
					
					uniform mat4 uModelViewMatrix;
					uniform mat4 uProjectionMatrix;
					
					varying vec2 vTextureCoord;
					
					void main() {
						gl_Position = uProjectionMatrix * uModelViewMatrix * vec4(aVertexPosition, 1.0);
						vTextureCoord = aTextureCoord;
					}
				`;

				const projectFragmentShader = `
					precision mediump float;
					
					varying vec2 vTextureCoord;
					
					uniform float uTime;
					uniform float uTransition;
					
					uniform sampler2D uSampler0; // Image Thumbnail
					uniform sampler2D uSampler1; // Hover Video
					
					void main() {
						vec2 uv = vTextureCoord;
						
						// Liquid wave distortion on transition
						float wave = sin(uv.y * 12.0 + uTime * 0.04) * 0.04 * sin(uTransition * 3.14159);
						vec2 displacedUv = vec2(uv.x + wave, uv.y);
						
						vec4 colorImg = texture2D(uSampler0, displacedUv);
						vec4 colorVid = texture2D(uSampler1, displacedUv);
						
						// Smoothly transition between static image and video
						gl_FragColor = mix(colorImg, colorVid, uTransition);
					}
				`;

				const cursorVertexShader = `
					precision mediump float;
					
					attribute vec3 aVertexPosition;
					attribute vec2 aTextureCoord;
					
					uniform mat4 uModelViewMatrix;
					uniform mat4 uProjectionMatrix;
					
					uniform float uTime;
					uniform vec2 uMouseVelocity;
					
					varying vec2 vTextureCoord;
					
					void main() {
						vec3 position = aVertexPosition;
						
						// Jelly elastic stretch based on mouse velocity
						float dist = distance(aTextureCoord, vec2(0.5));
						position.x += uMouseVelocity.x * dist * sin(position.y * 4.0 + uTime * 0.08) * 0.12;
						position.y += uMouseVelocity.y * dist * sin(position.x * 4.0 + uTime * 0.08) * 0.12;
						
						gl_Position = uProjectionMatrix * uModelViewMatrix * vec4(position, 1.0);
						vTextureCoord = aTextureCoord;
					}
				`;

				const cursorFragmentShader = `
					precision mediump float;
					
					varying vec2 vTextureCoord;
					
					uniform sampler2D uSampler0;
					uniform vec2 uMouseVelocity;
					
					void main() {
						vec2 uv = vTextureCoord;
						
						// Chromatic aberration (RGB separation offset by velocity)
						vec2 offset = uMouseVelocity * 0.025;
						
						float r = texture2D(uSampler0, uv + offset).r;
						float g = texture2D(uSampler0, uv).g;
						float b = texture2D(uSampler0, uv - offset).b;
						float a = texture2D(uSampler0, uv).a;
						
						gl_FragColor = vec4(r, g, b, a);
					}
				`;

				try {
					// Initialize curtains container
					curtains = new Curtains({
						container: 'canvas',
						watchScroll: false, // Updated manually in GSAP onUpdate for massive performance gain
						pixelRatio: Math.min(1.5, window.devicePixelRatio) // Limit pixel ratio to 1.5 for high-DPI/Retina screens
					});

					curtains.onError(() => {
						console.warn("WebGL/Curtains.js could not initialize.");
					}).onContextLost(() => {
						curtains?.restoreContext();
					});

					// On success, activate class on body to hide DOM fallback assets
					curtains.onSuccess(() => {
						document.body.classList.add('webgl-active');
						
						// 1. Set up WebGL Planes for each Project Card
						const mediaWrappers = document.querySelectorAll('.project-media-wrapper');
						mediaWrappers.forEach((wrapper) => {
							const card = wrapper.closest('.project-card');
							const video = wrapper.querySelector('.project-hover-video') as HTMLVideoElement | null;
							
							const planeParams = {
								vertexShader: projectVertexShader,
								fragmentShader: projectFragmentShader,
								uniforms: {
									time: { name: "uTime", type: "1f", value: 0 },
									transition: { name: "uTransition", type: "1f", value: 0 },
								}
							};

							const plane = new Plane(curtains!, wrapper as HTMLElement, planeParams);
							projectPlanes.push(plane);
							
							plane.onRender(() => {
								plane.uniforms.time.value++;
							});

							if (card) {
								card.addEventListener('mouseenter', () => {
									if (video) video.play().catch(() => {});
									gsap.to(plane.uniforms.transition, {
										value: 1,
										duration: 0.8,
										ease: 'power2.out'
									});
								});

								card.addEventListener('mouseleave', () => {
									if (video) {
										video.pause();
										video.currentTime = 0;
									}
									gsap.to(plane.uniforms.transition, {
										value: 0,
										duration: 0.6,
										ease: 'power2.out'
									});
								});

								// Open modal video on click
								card.addEventListener('click', (e) => {
									if ((e.target as HTMLElement).tagName !== 'BUTTON') {
										const videoUrl = card.getAttribute('data-video-url');
										if (videoUrl) openVideoModal(videoUrl);
									}
								});
							}
						});

						// 2. Set up WebGL Plane for Floating Service Image Trail
						if (cursorImageContainer && cursorImage) {
							const cursorImgPlaneParams = {
								vertexShader: cursorVertexShader,
								fragmentShader: cursorFragmentShader,
								uniforms: {
									time: { name: "uTime", type: "1f", value: 0 },
									mouseVelocity: { name: "uMouseVelocity", type: "2f", value: [0, 0] },
								}
							};

							const cursorPlane = new Plane(curtains!, cursorImageContainer, cursorImgPlaneParams);
							
							cursorPlane.onRender(() => {
								cursorPlane.uniforms.time.value++;
								if (cursorImageContainer.classList.contains('active')) {
									cursorPlane.uniforms.mouseVelocity.value = [velocity.x, velocity.y];
									cursorPlane.updatePosition(); // Track moving cursor element position only when visible/active
								}
							});

							// Listen to changes in source image
							const serviceItems = document.querySelectorAll('.service-item');
							serviceItems.forEach((item) => {
								const imageUrl = item.getAttribute('data-image-url');
								
								item.addEventListener('mouseenter', () => {
									if (imageUrl) {
										cursorImage.src = imageUrl;
										cursorImage.onload = () => {
											// Rebind the texture source once loaded
											cursorPlane.textures[0].setSource(cursorImage);
										};
										cursorImageContainer.classList.add('active');
										
										if (cursor && cursorFollower) {
											cursor.style.opacity = '0';
											cursorFollower.style.opacity = '0';
										}
									}
								});

								item.addEventListener('mouseleave', () => {
									cursorImageContainer.classList.remove('active');
									if (cursor && cursorFollower) {
										cursor.style.opacity = '1';
										cursorFollower.style.opacity = '1';
									}
								});
							});
						}
					});
				} catch (err) {
					console.error("Failed to boot Curtains.js shaders:", err);
				}
			}
		</script>
	</body>
</html>
